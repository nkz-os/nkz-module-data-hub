{
  "id": "datahub",
  "name": "datahub",
  "display_name": "DataHub",
  "version": "1.0.0",
  "description": "High-performance analytical canvas (Data Canvas) to cross variables from any source, export ranges, and run predictive models via Intelligence.",
  "short_description": "Analytical canvas and data export",
  "icon": "line-chart",
  "icon_url": "",
  "author": { "name": "Nekazari Team", "email": "", "organization": "nkz-os" },
  "category": "analytics",
  "module_type": "ADDON_FREE",
  "required_plan_type": "basic",
  "pricing_tier": "FREE",
  "route_path": "/datahub",
  "label": "DataHub",
  "required_roles": ["Farmer", "TenantAdmin", "PlatformAdmin"],
  "navigation": { "enabled": true, "priority": 55, "section": "modules" },
  "dependencies": { "sdk_version": "^1.0.0", "react_version": "^18.3.1", "platform_version": "^2.0.0" },
  "permissions": {
    "api_access": ["/api/datahub/*", "/api/timeseries/*", "/api/intelligence/*"],
    "storage_access": false,
    "external_requests": []
  },
  "accent": {
    "base": "#06B6D4",
    "soft": "#CFFAFE",
    "strong": "#0891B2"
  },
  "build_config": { "type": "iife", "remote_entry_url": "/modules/datahub/nkz-module.js" },
  "slots": {
    "layer-toggle": [],
    "context-panel": [
      {
        "tab": {
          "label": "DataHub",
          "icon": "line-chart",
          "accent": "cyan"
        }
      }
    ],
    "bottom-panel": [
      {
        "tab": {
          "label": "DataHub Quick",
          "icon": "line-chart",
          "accent": "cyan"
        }
      }
    ],
    "entity-tree": [],
    "map-layer": [],
    "dashboard-widget": []
  },
  "surfaces": {
    "panel": {
      "controls": ["chart", "toolbar", "series-rail", "footer"],
      "supportedChartTypes": ["timeseries", "correlation"]
    },
    "dashboard": {
      "features": ["workspace-save", "workspace-load", "export", "predict", "time-range-presets"]
    },
    "integrations": {
      "features": ["pat-management", "power-bi-hints", "api-query-builder"]
    },
    "lab": {
      "features": ["jupyterlite-embed"]
    }
  },
  "metadata": {
    "icon": "📊",
    "color": "#0EA5E9",
    "features": ["Data Canvas", "Multi-source timeseries", "Export CSV/Parquet", "Intelligence predict"],
    "screenshots": [],
    "changelog_url": null,
    "documentation_url": null
  }
}
